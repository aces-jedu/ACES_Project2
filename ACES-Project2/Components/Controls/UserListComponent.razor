    private async Task LoadRoles()
    {
        if (users != null)
        {
            availableRoles = users
                .Select(u => u.RoleName)
                .Where(r => !string.IsNullOrEmpty(r))
                .Distinct()
                .ToList();
        }
    }

    private void ApplyFilters()
    {
        if (users == null) return;

        var query = users.AsEnumerable();

        if (!string.IsNullOrEmpty(searchTerm))
        {
            query = query.Where(u =>
                u.FirstName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
                u.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true);
        }

        if (!string.IsNullOrEmpty(selectedRoleFilter))
            query = query.Where(u => u.RoleName == selectedRoleFilter);

        if (!string.IsNullOrEmpty(selectedStatusFilter))
        {
            var status = int.Parse(selectedStatusFilter);
            query = query.Where(u => u.IsActive == status);
        }

        query = sortColumn switch
        {
            "FirstName" => sortAscending ? query.OrderBy(u => u.FirstName) : query.OrderByDescending(u => u.FirstName),
            "Email" => sortAscending ? query.OrderBy(u => u.Email) : query.OrderByDescending(u => u.Email),
            "RoleName" => sortAscending ? query.OrderBy(u => u.RoleName) : query.OrderByDescending(u => u.RoleName),
            "IsActive" => sortAscending ? query.OrderBy(u => u.IsActive) : query.OrderByDescending(u => u.IsActive),
            _ => query.OrderBy(u => u.FirstName)
        };

        filteredUsers = query.ToList();
        currentPage = 1;
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
            sortAscending = !sortAscending;
        else
        {
            sortColumn = column;
            sortAscending = true;
        }

        ApplyFilters();
    }

    private void OnRoleFilterChange(ChangeEventArgs e)
    {
        selectedRoleFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnStatusFilterChange(ChangeEventArgs e)
    {
        selectedStatusFilter = e.Value?.ToString() ?? "";
        ApplyFilters();
    }

    private void OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int size))
        {
            pageSize = size;
            currentPage = 1;
        }
    }

    private void GoToPage(int page) => currentPage = page;
    private void PreviousPage() { if (currentPage > 1) currentPage--; }
    private void NextPage() { if (currentPage < totalPages) currentPage++; }

    private async Task DebounceSearch()
    {
        isSearching = true;

        debounceTimer?.Dispose();

        debounceTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                ApplyFilters();
                isSearching = false;
                StateHasChanged();
            });
        }, null, 500, Timeout.Infinite);
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        ApplyFilters();
    }

    private async Task OpenModalForCreate() =>
        await addUserModal.OpenForCreateAsync();

    private async Task OpenModalForEdit(string userId) =>
        await addUserModal.OpenForEditAsync(userId);

    private async void RefreshUserList()
    {
        await LoadUsers();
        StateHasChanged();
    }
}
