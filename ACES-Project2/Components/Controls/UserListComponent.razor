                {
                    @foreach (var user in filteredUsers)
                    {
                        <UserListItemComponent _user="user"
                                               OnEditUser="OpenModalForEdit" />
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            @if (isSearching)
                            {
                                <span>Searching...</span>
                            }
                            else if (!string.IsNullOrEmpty(searchTerm) ||
                            !string.IsNullOrEmpty(selectedRoleFilter) ||
                            !string.IsNullOrEmpty(selectedStatusFilter))
                            {
                                <span>
                                    No users found matching your filters.
                                    <a href="#" @onclick="ClearAllFilters">Clear filters</a>
                                </span>
                            }
                            else
                            {
                                <span>No users available.</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<AddUserModal @ref="addUserModal" OnClose="RefreshUserList" />

@code {
    private List<ManageUsers>? users;
    private List<ManageUsers> filteredUsers = new();
    private AddUserModal addUserModal;
    private HubConnection? hubConnection;

    // Search and filter properties
    private string searchTerm = string.Empty;
    private string selectedRoleFilter = string.Empty;
    private string selectedStatusFilter = string.Empty;
    private string sortColumn = "FirstName";
    private bool sortAscending = true;
    private bool isSearching = false;
    private Timer? debounceTimer;

    // PAGINATION
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalPages => (int)Math.Ceiling((double)filteredUsers.Count / pageSize);

    private List<ManageUsers> pagedUsers =>
        filteredUsers
            .Skip((currentPage - 1) * pageSize)
            .Take(pageSize)
            .ToList();
      
    private int totalUsers => users?.Count ?? 0;

    // Available roles (you might want to fetch these from your service)
    private List<string> availableRoles = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
        await LoadRoles();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/userHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("UsersUpdated", async () =>
        {
            using var scope = ScopeFactory.CreateScope();
            var viewUsersUseCase = scope.ServiceProvider.GetRequiredService<IViewUsersUseCase>();
            var updatedUsers = (await viewUsersUseCase.ExecuteAsync()).ToList();

            await InvokeAsync(() =>
            {
                users = updatedUsers;
                ApplyFilters();
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadUsers()
    {
        users = (await ViewUsersUseCase.ExecuteAsync()).ToList();
        ApplyFilters();
    }

    private async Task LoadRoles()
    {
        // Extract unique roles from users
        if (users != null)
        {
            availableRoles = users
                .Select(u => u.RoleName)
                .Where(r => !string.IsNullOrEmpty(r))
                .Distinct()
                .ToList();
        }
    }

    private async Task LoadRoles()
    {
        if (users != null)
        {
            availableRoles = users
                .Select(u => u.RoleName)
                .Where(r => !string.IsNullOrEmpty(r))
                .Distinct()
                .ToList();
        }
    }

    private void ApplyFilters()
    {
        if (users == null) return;

        var query = users.AsEnumerable();

        // Apply search filter
        if (!string.IsNullOrEmpty(searchTerm))
        {
            query = query.Where(u =>
                u.FirstName?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
                u.Email?.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) == true
            );
        }

        // Apply role filter
        if (!string.IsNullOrEmpty(selectedRoleFilter))
        {
            query = query.Where(u => u.RoleName == selectedRoleFilter);
        }

        // Apply status filter
        if (!string.IsNullOrEmpty(selectedStatusFilter))
        {
            var status = int.Parse(selectedStatusFilter);
            query = query.Where(u => u.IsActive == status);
        }

        // Apply sorting
        query = sortColumn switch
        {
            "FirstName" => sortAscending
                ? query.OrderBy(u => u.FirstName)
                : query.OrderByDescending(u => u.FirstName),
            "Email" => sortAscending
                ? query.OrderBy(u => u.Email)
                : query.OrderByDescending(u => u.Email),
            "RoleName" => sortAscending
                ? query.OrderBy(u => u.RoleName)
                : query.OrderByDescending(u => u.RoleName),
            "IsActive" => sortAscending
                ? query.OrderBy(u => u.IsActive)
                : query.OrderByDescending(u => u.IsActive),
            _ => query.OrderBy(u => u.FirstName)
        };

        filteredUsers = query.ToList();
    }

    private async Task DebounceSearch()
    {
        isSearching = true;
        StateHasChanged();

        if (debounceTimer != null)
        {
            await debounceTimer.DisposeAsync();
        }

        debounceTimer = new Timer(_ =>
        {
            InvokeAsync(() =>
            {
                ApplyFilters();
                isSearching = false;
                StateHasChanged();
            });
            debounceTimer?.DisposeAsync();
        }, null, 500, Timeout.Infinite);
    }

    private void ClearSearch()
    {
        searchTerm = string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void OnRoleFilterChange(ChangeEventArgs e)
    {
        selectedRoleFilter = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void OnStatusFilterChange(ChangeEventArgs e)
    {
        selectedStatusFilter = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void SortBy(string column)
    {
        if (sortColumn == column)
        {
            sortAscending = !sortAscending;
        }
        else
        {
            sortColumn = column;
            sortAscending = true;
        }
        ApplyFilters();
        StateHasChanged();
    }

    private void ClearAllFilters()
    {
        searchTerm = string.Empty;
        selectedRoleFilter = string.Empty;
        selectedStatusFilter = string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private async Task OpenModalForCreate()
    {
        await addUserModal.OpenForCreateAsync();
    }

    private async Task OpenModalForEdit(string userId)
    {
        await addUserModal.OpenForEditAsync(userId);
    }

    private async void RefreshUserList()
    {
        await LoadUsers();
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        if (debounceTimer != null)
        {
            await debounceTimer.DisposeAsync();
        }

        if (hubConnection != null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
