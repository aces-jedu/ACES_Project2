                        @if (sortColumn == "Email")
                        {
                            <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
                        }
                    </th>
                    <th @onclick="@(() => SortBy("RoleName"))" style="cursor: pointer;">
                        Role
                        @if (sortColumn == "RoleName")
                        {
                            <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
                        }
                    </th>
                    <th @onclick="@(() => SortBy("IsActive"))" style="cursor: pointer;">
                        Status
                        @if (sortColumn == "IsActive")
                        {
                            <i class="bi bi-arrow-@(sortAscending ? "up" : "down")"></i>
