@using Microsoft.AspNetCore.SignalR.Client
@inject IViewUsersUseCase ViewUsersUseCase
@inject NavigationManager Navigation
@inject IServiceScopeFactory ScopeFactory

<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Email</th>
            <th>Role</th>
            <th>Status</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (users is not null && users.Count > 0)
        {
            @foreach (var user in users)
            {
                <UserListItemComponent _user="user"
                                       OnEditUser="OpenModalForEdit" />
            }
        }
    </tbody>
</table>

<button class="btn btn-primary" @onclick="OpenModalForCreate">
    Add User
</button>

<AddUserModal @ref="addUserModal" OnClose="RefreshUserList" />

@code {
    private List<ManageUsers>? users;
    private AddUserModal addUserModal;
    private HubConnection? hubConnection;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Navigation.ToAbsoluteUri("/userHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On("UsersUpdated", async () =>
        {
            using var scope = ScopeFactory.CreateScope();
            var viewUsersUseCase = scope.ServiceProvider.GetRequiredService<IViewUsersUseCase>();
            var updatedUsers = (await viewUsersUseCase.ExecuteAsync()).ToList();

            // ⚡ Switch to UI thread
            await InvokeAsync(() =>
            {
                users = updatedUsers;
                StateHasChanged();
            });
        });

        await hubConnection.StartAsync();
    }

    private async Task LoadUsers()
    {
        users = (await ViewUsersUseCase.ExecuteAsync()).ToList();
    }

    private async Task OpenModalForCreate()
    {
        await addUserModal.OpenForCreateAsync();
    }

    private async Task OpenModalForEdit(string userId)
    {
        await addUserModal.OpenForEditAsync(userId);
    }

    private async void RefreshUserList()
    {
        await LoadUsers();
        StateHasChanged();
    }
}